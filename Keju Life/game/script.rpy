# 定义角色
define f = Character("父亲")
define l = Character("李先生")
define n = Character("科举人生")
define w = Character("王兄")
define z = Character("知县")
define y = Character("衙役")
define k = Character("考官")
define player = Character("[player_name]", color="#1e88c5")

label start:
    # 1. 弹出输入框获取名字，strip() 用于去除玩家不小心打出的多余空格，length 限制字数
    $ player_name = renpy.input("请输入你的名字，未来的状元郎：", length=10).strip()
    
    # 2. 防呆判定：如果玩家什么都没输入直接按了回车，给一个默认名字
    if not player_name:
        $ player_name = "ZJUer"
    # 初始化文运值
    $ wenyun = 0
    $ cheat = 0
    $ spill = 0
    jump chapter_1_spring

# ================= 春季剧情 =================
label chapter_1_spring:
    n "你自 8 岁入家塾，先读《小学》、习楷书，从日诵二百字循序渐进。15 岁束发之年，是你筑牢科举根基、攒足应试实力的关键一年。"
    n "二月仲春，府中正堂。梨花落满青石板，堂内炭火余温未散，案上摊着《朱子读书法》与十三经总目，父亲端坐上首，家塾李先生侍立一侧，你躬身站在堂下。"
    f "你已十五束发，当立科举之志。此乃无半分捷径之硬仗，十三经需得一字一句烂熟于心，方能闯过层层关隘。今年定课，你打算如何行之？"

    menu:
        "于是你选择"

        "躬身垂首，正色应答：“儿谨遵父亲与先生教诲，每日定课千字，分段熟读百遍、背诵百遍，绝不打半分折扣。”":
            n "父亲与李先生相视一眼，均露出赞许之色。父亲当场将自己当年备考手订的《朱子读书章程》手卷传给你，李先生特意调整授课节奏，每日额外加半个时辰的经书要义讲解。"
            n "你自此定下每日不辍的读书规矩，由此扎稳了根基。"
            $ wenyun += 2
            n "【系统提示】文运值+2"

        "面露恭谨，轻声道：“儿怕贪多嚼不烂，恳请父亲先定每日五百字的功课，待熟练之后再渐次增加，稳扎稳打。”":
            n "父亲沉吟片刻点头应允，李先生也附和循序渐进本就是朱子读书法的核心，不求快但求成。"
            n "你的课业进度虽稍缓，但每背过一段都记得十分牢固，全无半分生疏。"
            $ wenyun += 1
            n "【系统提示】文运值+1"

        "意气风发，拱手道：“男儿当立壮志，儿愿每日定课两千字，早日攒足应试实力，不负家门期望！”":
            f "欲速则不达！朱子教你读书不可先贪多，你这般浮躁冒进，只重数量不重精思，最终只会竹篮打水。"
            n "于是父亲虽仍按每日千字定课，却对你多了苛责，此后日日查课，稍有懈怠便严加训斥。"
            $ wenyun -= 1
            n "【系统提示】文运值-1"

    jump chapter_1_summer

# ================= 夏季剧情 =================
label chapter_1_summer:
    n "六月三伏，西窗书斋。窗外蝉鸣聒噪，暑气蒸腾，即便案边放了冰盆，也难挡热浪翻涌。案上摊着近二十万字的《左传》—— 十三经里最难啃的硬骨头之一。"
    n "你已经卡在 “襄公二十二年” 的传文里整整三天。这段传文史事盘根错节，文辞古奥拗口，你按往日的法子读了几十遍，还是背得颠三倒四，原定的日诵进度迟迟赶不上。"
    n "今日李先生告假回乡，父亲去了省城赴同年之宴，书斋里只有你一人。窗外的蝉鸣越发热闹，你心里的烦躁也越积越盛，猛地把笔搁在砚台上，看着满架的经书，一时竟不知该如何是好。"

    menu:
        "于是你打算做出一个选择："

        "深吸一口气收束心神，把拗口的大段拆成三句一小段，谨遵朱子之法，每段先看读五十遍，再默背五十遍，直到全部背完。":
            n "拆段熟读之后，你竟读懂了此前没弄明白的史事逻辑，文义豁然贯通，你从日头当午读到暮色西沉，终于把这段传文背得滚瓜烂熟。第二日李先生回来，连连称赞你得了读书的真意，特意为你补讲了《左传》全本的编年要义。"
            $ wenyun += 3
            n "【系统提示】文运值+3"

        "合上经书，翻出父亲收藏的《左传集解》《春秋属辞》，先看前贤的注疏弄懂文义，理清人物与史事脉络，再回头背诵原文。":
            n "顺着前贤的注解，你很快理清了这段传文里的人物关系和事件始末，原本拗口的文字一下子通顺起来，弄懂文义再背诵，果然事半功倍，天黑前就把落下的进度补了回来。"
            n "晚间父亲回来，得知你没按定课先背原文，虽没斥责，却也告诫你 “注疏是辅，经书是本，不可本末倒置”。"
            $ wenyun += 2
            n "【系统提示】文运值+2"

        "心里烦躁难安，索性把经书一合，溜出府去，找相熟的同窗去城外荷塘泛舟纳凉。":
            n "你把课业全抛在了脑后，直到天黑才醉醺醺回府。第二日李先生查课，你背得磕磕绊绊，被罚抄全文十遍，父亲得知后，收了你房里的所有闲书，严令你课业未完不得出府半步。"
            $ wenyun -= 2
            n "【系统提示】文运值-2"

    jump chapter_1_autumn

# ================= 秋季剧情 =================
label chapter_1_autumn:
    n "八月乡试放榜日，省城贡院门外。人山人海，红底黑字的乡试榜单高高挂起，喝彩声与哭嚎声交织在一起。"
    n "你挤在人群里，亲眼看见二十出头的书生找到自己的名字，瞬间红了眼眶，被仆从簇拥着披红挂彩，跨上高头大马扬长而去；也看见头发花白的老者，来来回回看了十几遍榜单，最终瘫坐在地上，喃喃自语 “又落榜了，整整三十年了……”。"
    n "科举的真相就这么赤裸裸铺在你眼前：千军万马过独木桥，一朝登科便可光宗耀祖，可更多的人，是蹉跎半生，一无所获。"
    n "父亲拍了拍你的肩膀，低声询问："
    f "今日见此情景，你心里作何想？"

    menu:
        "于是你选择"

        "躬身正色，字字坚定：“儿观眼前之悲喜后乃知，科举之路无半分侥幸。唯有沉心苦读，筑牢经书根基，方能不负所学，将来为国效力。”":
            n "父亲闻言眼中满是欣慰，当即带你拜见了此次乡试的主考官 —— 他的同年好友。主考官见你少年有志、谈吐沉稳，特意给你讲了科举应试的核心要诀，还赠了你他亲手批注的中式程墨范文。"
            n "你回府之后读书的劲头更足，全无半分懈怠。"
            $ wenyun += 3
            n "【系统提示】文运值+3"

        "沉默许久，轻声道：“见落榜之人这般落魄，儿心中惶恐，只盼自己日后能稳扎稳打，不要落得这般境地。”":
            f "（叹了口气）求稳之心人皆有之，但科举之路，怕输的人往往赢不了。唯有心无旁骛，只问耕耘不问收获，方能走得长远。"
            n "他没斥责你，却也取消了原本带你拜见江南名儒的安排，只带你回了客栈。此后读书，你虽依旧勤勉，却总忍不住患得患失，效率打了几分折扣。"
            # 文运值+0，无需写计算逻辑
            n "【系统提示】文运值未变动"

        "看着中举人的风光，眼中满是羡慕，脱口道：“中举竟这般风光无限，儿日后也要一举登科，让所有人都高看我一眼！”":
            f "你读书科举，只为了人前风光？圣贤书教你的修身齐家治国平天下，你都读到哪里去了？心术不正，文气便浮，文章写得再好，也入不了真正有识见的考官的眼！"
            n "回府之后，父亲罚你抄《朱子家训》一百遍，每日额外加讲修身立志的课程，对你的管教愈发严厉。"
            $ wenyun -= 1
            n "【系统提示】文运值-1"

    jump chapter_1_winter

# ================= 冬季剧情 =================
label chapter_1_winter:
    n "腊月深冬，内堂暖阁。天降大雪，窗外银装素裹，暖阁里炭火正旺，案上摆着你这一年的课业簿、默写的经书手稿，还有摊开的十三经注疏。"
    n "父亲与李先生端坐上首，为你做这一年的岁末终考。李先生先考你背诵了今年定课的的篇目，对答完毕，李先生捻须颔首，看向父亲。"
    n "父亲拿起狼毫，在宣纸上写下一道《论语》的经义题，推到你面前，沉声道："
    f "经书背得熟，是根基；能用圣贤之意写文章，才是科举的真本事。一炷香之内，写好这道题的破题与承题，让我看看你这一年，到底学到了什么。"

    menu:
        "于是你选择"
        "沉心静气，摒除杂念，谨遵先生教的经义章法，字字紧扣经书原义，不炫技、不浮夸，稳稳当当地写完。":
            n "一炷香燃尽，你呈上习作。父亲与李先生逐字看完，相视一笑。父亲把文稿递回给你，语气里满是欣慰：“这一年，你不仅长了学问，更磨了心性，这才是科举正道该有的样子。”"
            n "除夕夜，父亲把自己当年备考时用的十三经朱笔批注本传给了你，这是家族里只传给潜心科举子弟的核心家学资料。"
            $ wenyun += 2
            n "【系统提示】文运值+2"

        "放下笔，躬身道：“父亲，儿以为，经书是本，写作是末。如今儿对经书的掌握还未到极致，恳请父亲容我先把十三经背熟吃透，再专心打磨经义写作的功夫。”":
            n "父亲沉吟片刻，点头应允了你的请求，只让你口述了破题的核心思路，没再逼你写全文。李先生也附和道，先固本再培末，也是正道。"
            n "只是你刻意回避了写作短板，这一年的经义写作能力全无长进，年末复盘时，也只完成了原定经书课业的七成。"
            $ wenyun += 1
            n "【系统提示】文运值+1"

        "想在父亲面前展露才华，行文间引了诸多史书典故与唐宋大家的文句，辞藻华丽，想写得一鸣惊人。":
            n "你文思泉涌，很快写完了一篇辞藻华丽的破题文章，自觉十分得意。"
            n "可父亲看完，却皱紧了眉，把文章拍在案上"
            f "经义之文，首重义理纯正，根基扎实。你满篇浮华辞藻，偏离经书原义，不过是花架子，科举场上，最忌讳的就是这个！"
            n "李先生也叹了口气，说你读书虽多，却没沉下心。过年期间特意为你加开了经义写作的专项课业。"
            # 文运值+0
            n "【系统提示】文运值未变动"

    n "除夕的爆竹声响起，你十五岁的束发读书时光就此落下帷幕。"
    n "这一年里的每一次选择，都化作了你笔下的笔墨、胸中的文气，沉淀为科举之路上的根基。"
    n "无论得失，你都已走完了这关键的一年，接下来，便是整装待发，迎接科举考场的真正考验。"
    jump chapter_2


# ================= 第二章：乡试 =================
label chapter_2:
    n "七月末，海宁县码头，晨雾未散，你望着远处的河面，心里清楚，这一路，是你人生第一场真正的科举大考，是你苦读十余载的一次终极检验。"
    n "父母在岸边反复叮嘱你保重身体，眼里满是期许与担忧，知县亲手将一封封红封递到你们手中，笑着道："
    z "诸位皆是本县的青年才俊，此去省城赴考，本县备下薄礼宾兴费，祝诸位旗开得胜，金榜题名，为我县争光。"
    n "同行的老秀才凑过来道："
    w "贤弟，咱们走水路去省城，船家说可以在船头竖起“奉旨浙江省乡试”的大旗，沿道所有内地关税全免，能省不少麻烦，你看要不要一起？"

    menu:
        "你沉思片刻，权衡利弊，做出了选择："
        "颔首应允，规规矩矩走水路赴省，沿途闭门在船上温书，不与旁人闲谈嬉闹。":
            n "你每日在船上临窗温书，把四书五经、往年中式程墨反复翻看，将乡试三场的规矩烂熟于心，原本的考前紧张感渐渐消散，心态愈发沉稳。"
            n "同船的生员见你这般勤勉，都暗自佩服，不敢前来打扰。"
            n "一路平安，提前三日抵达省城。"
            $ wenyun += 2
            n "【系统提示】文运值+2"

        "婉拒竖旗，和相熟的同届生员结伴走旱路赴省，沿途走走停停，顺路拜访当地书院的文友。":
            n "你和同伴走旱路赴省，沿途拜访了几位相熟的文友，饮酒论诗、交流经义，一路十分畅快，考前的紧绷感消散了大半。"
            n "但路上耽误了不少时日，比原定时间晚了一日才抵达省城，考前准备的时间被大幅压缩，心里难免有些慌乱。"
            # 文运值+0
            n "【系统提示】文运值未变动"

        "应许同行，但无心温书，每日和同船的生员打牌饮酒。":
            n "大旗竖在船头，沿途关卡顺利放行，但你一路只顾着和同伴玩乐，几乎没碰书本。"
            n "抵达省城后，之前背熟的经文、经义章法都生疏了不少，夜里躺在床上，第一次赴考的紧张感瞬间涌了上来，整夜辗转难眠。"
            $ wenyun -= 1
            n "【系统提示】文运值-1"

    n "乡试入场前，必先办卷，你先挤到卖卷厂的柜台前，按规矩买了三份答题纸，并索要了证明书。"
    n "接着你又到了布政司收卷局。衙役高声道："
    y "按印！填亲供！年龄、身高、面色、有无胡须、本籍住址、祖上三代姓名存殁，一字都不能错！填完统一盖布政司印章，全数留存归档！"
    y "进场后你再凭身份领卷，若是卷子遗失，我们会出示留存的三份底档给你调取备用卷！"
    y "这套手续本该进场后办，如今提前办，全为了给你们进场省时间，半点错不得！"
    n "于是你仔细认真将其填好，回到客栈继续温书，静待乡试的到来。"
    
label cheat_choice_pre:
    n "八月初七夜，省城客栈。隔壁房间传来生员们的谈笑声，你的考篮已经收拾妥当，母亲亲手给你做的包子、馒头用油纸包好，笔墨砚台、寝具一一清点完毕。"
    n "就在这时，和你同住一个客栈的同县老秀才王兄，悄悄推开了你的房门。他反手关上房门，从怀里掏出一个油布包，放在你桌上，低声道："
    w "贤弟，你是第一次赴考，不知道这里面的门道。这里面是四书五经的缩印小抄，缝在衣服夹层里，搜身根本查不出来。"
    w "我还买通了头门的卫兵，到时候搜身只会走个过场。你少年英才，总不能第一次就折在这里，要不要一起？"

# 作弊选择循环点
label cheat_choice:
    menu:
        "于是你选择"

        "脸色一沉，将油布包推了回去，正色道：“王兄，科举是圣贤之道，我读了十年书，绝不会做这种舞弊苟且之事。你也赶紧收起来，一旦被查，就是身败名裂，永不录用的下场！”":
            n "王兄叹了口气，收起油布包摇着头走了。你关上门，重新清点了考篮里的东西，确保没有任何违禁物品。做完这一切，你心里坦坦荡荡，躺到床上很快便睡着了，养足了第二日入场的精神。"
            $ wenyun += 3
            n "【系统提示】文运值+3"

        "心一横，收下油布包，按王兄说的，把小抄缝进了衣服夹层里，又给了他五两银子，托他和卫兵打个招呼。":
            n "做完这一切，你心里又慌又乱，一夜没能合眼。"
            $ cheat = 1

    jump enter_exam_part1

label enter_exam_part1:
    n "八月初八零点整，“咚 ——” 第一发号炮轰然炸响，震得你耳膜发颤，这是提醒考生整理行装，准备点名。半小时后鸣放号炮两发，一点左右鸣放号炮三发。第三遍号炮后，考场大门缓缓打开。"
    n "凌晨三点左右乌泱泱的考生在考场门口汇集，办事员、教官、门斗纷纷就位..."
    n "终于从办事员的点唤声中听了你的名字，本县的教官带着门斗上前，确认是你本人无误，挥手放你前行。"
    n "你背着考篮，一步步走向贡院头门，心里清楚，跨过这道门，就是你十年读书的终极考场。"
    n "你走到头门，四个卫兵立刻围了上来，一人抓着你的胳膊，一人翻你的考篮，一人搜你的全身，连头发缝、鞋底都不放过..."
    
    if cheat == 0:
        n "一个卫兵拿起你母亲给你做的包子，二话不说掰开，检查里面有没有藏小抄，确认无误后才扔回你的考篮里。"
        n "翻来覆去搜了两刻钟，没发现任何违禁品，卫兵才递给你一块刻着编号的竹牌 —— {b}照入笺{/b}，放你进入头门。"
    else:
        n "但有你买通的卫兵帮助，你顺利通过了头门。"

    n "你拿着照入笺走到第二道仪门，衙役收了竹牌"

    if cheat == 0:
        n "又仔细检查了你的衣服，确认没有夹带，递给你一本印着考试守则的《三场程式》，沉声道"
        "卫兵" "进去吧，按号找自己的号舍，不得乱闯！"
    else:
        n "没想到，这道门竟然要进行服装检查，缝在衣服里的小抄最终还是被发现，你也被逐出了考场。"
        n "后来你得知，那位王兄竟私吞了二两银子，你懊悔不已，但也无可奈何。"
        n "【坏结局提示】你被逐出考场，失去参加接下来考试的资格。你将返回客栈，重新选择是否接受王兄的作弊提议。"
        jump cheat_choice_pre

    n """
    穿过仪门，便是龙门。跨过龙门的那一刻，你终于看清了号舍的全貌：上万间号舍排成一条条长巷，如同迷宫一般。

    你找到了自己的号舍，窄小的空间里只有上下两块木板,白天抽出来当书桌，晚上拼起来当床，连转身都费劲。

    初八傍晚，所有考生全部入场完毕，只听 “咚” 的一声号炮，贡院所有大门轰然关闭，监临官亲自用封条封印，不到初十考试结束，绝不可能开启。

    你坐在号舍里，听着外面落锁的声音，知道接下来的两夜一天，你只能在这三尺见方的空间里度过。

    官府虽规定提供饮食，但早就听闻里面的饭食掺着沙子、难以下咽，你吃了点带来的包子。

    夜里，你把木板拼好当床，裹着带来的铺盖躺下。

    号舍里又闷又潮，墙角还有蟑螂爬过，隔壁号舍的考生翻来覆去的咳嗽声、叹气声听得一清二楚，你在紧张与挣扎中慢慢入睡。

    初九清晨，天刚蒙蒙亮,号炮声响起，衙役走到你的号舍前，递上题纸与答题纸。

    考官上前，再次核对了你的相貌、亲供信息，确认是你本人无误，拿起朱笔，在你的答题纸上盖了一个鲜红的 “对” 字印章。
    
    —— 这是对号戳，证明考生本人入场，无替考舞弊。

    你摊开题纸，只见上面印着：四书义三题，五言八韵诗一题，限 “东” 韵。

    你握着笔，深吸一口气，再次默念规矩：四书文正文不得超过七百字，加注、涂改合计不得超过一百字，每题末尾需注明正文字数、加注字数、涂改字数。。

    思索片刻后，奋笔疾书起来。
    """

# 熬夜写卷选择循环点
label midnight_choice:
    n "到夜间，天色全黑，号巷里只有星星点点的烛火。"
    n "一更天刚过，你正写到关键处，忽然听到号巷尽头传来一阵低低的喧哗，紧接着是重物落地的声音，还有几个衙役压低声音说话————"
    "衙役A" "快！抬过来！从墙那边递出去！别让考生看见！"
    "衙役B" "都硬了，唉，又是一个熬不住的……"
    n "你心里一紧，想起书院先生说过，贡院号舍环境恶劣，每年乡试都有考生熬不住生病、甚至死在里面。"
    n "按规矩，考场封门后绝不能开大门，死者只能越过围墙、破墙抬出去。"
    n "烛火摇曳，你看着号舍外漆黑的巷子，第一次赴考的紧张瞬间被放大，仿佛能听到墙外传来的哭声，心里一阵发毛。"

    menu:
        "于是你选择"

        "稳下心神，摒除杂念，把烛火挪到远离答卷的位置，稳下心神，一字一句写完最后一道四书文，再吹灭蜡烛休息。":
            n "你认认真真写完了最后一道题，又逐字逐句核对了三道四书文的字数、加注涂改数，确认完全符合规矩，试帖诗也严格遵循限韵，没有出韵。"
            n "核对完毕，你把答卷小心翼翼放在高处，吹灭蜡烛躺下休息，一夜安睡。"
            $ wenyun += 4
            n "【系统提示】文运值+4"
            jump end_of_part1

        "心里发慌，不敢再熬夜作答，吹灭蜡烛躺下，打算天亮再写最后一题。":
            n "你吹灭了蜡烛，可脑子里全是刚才的动静，第一次赴考的忐忑让你翻来覆去直到天亮都没睡着，精神极度疲惫。"
            n "第二天天亮，你强撑着精神写完了最后一题，却因为精神不济，写错了两个字，涂改处超出了规定字数，还险些把试帖诗的韵脚写错，虽及时改了过来，却也留下了瑕疵。"
            # 文运值+0
            n "【系统提示】文运值未变动"


        "不管不顾，点着蜡烛熬夜赶工，为了赶进度写得飞快。":
            n "你只顾着赶进度，丝毫没注意烛油溅到了答卷上。"
            $ spill = 1

label end_of_part1:
    n "初十六点整，号炮轰然炸响，奏乐声随之响起，考官的声音沿着长巷传来"
    "考官" "考试结束！停笔！准备交卷！"
    n "你将楷书誊写的答案正文和草稿交到场内的至公堂，各县分别处理。"
    n "每收到一份答卷，受卷官都要检查其中有没有违规的地方。"

    if spill == 0:
        n "受卷官检查无误，递给你一个名为“照出笺”的竹制出门许可牌。"
        n "于是你收拾好行李，等待聚集到一定的人数后，结成一队，开门离开考场。"
    else:
        n "你的试卷因被烛油污损被判为“犯贴”，受卷官立即报告监临官，并在场外的“紫榜”（又称“蓝榜”）上公示了你的姓名，你由此失去了参加接下来考试的资格。"
        n "【坏结局提示】你的试卷被判为犯贴，失去参加接下来考试的资格。你将回到熬夜写卷的选择点。"
        jump midnight_choice

    n "你走出贡院，看着外面的人潮，心里五味杂陈 —— 人生第一场乡试的头场已毕，可还有第二场、第三场在等着你。"

# ================= 乡试第二场 =================
label exam_part2:
    n "八月十一日凌晨，你准备参加乡试的第二场，和头场一样，号炮三响，点名、搜身、入场，流程分毫不差。"
    n "你第二次走进贡院，这一次，你心里比头场平静了许多，早早整理好了考具，躺下休息，养足精神应对次日的考试。"
    n "八月十二日清晨，题纸与答题纸按时发放。"
    n "第二场的试题为五经义四道，此外，还必须要默写头场你所作的四书文的起讲部分，或是试帖诗的全诗—— 这是防替考、防舞弊的关键规矩。"

label second_exam_choice:
    menu:
        "你稍作思考，决定了第二场的答题思路："
        "先认认真真默写头场的四书文起讲，逐字逐句核对，确认和头场写的一字不差，再按规矩答完五经义四道题。":
            n "你按部就班，每一道题都写得章法严谨，格式合规，日落之前就写完了所有内容，反复核对无误后，才安心休息，第二天顺利交卷。"
            $ wenyun += 4
            n "【系统提示】文运值+4"
            jump exam_part3

        "先答五经义的题目，最后凭记忆默写头场的内容。":
            n "你五经义题的部分答的不错，但临交卷前才匆匆默写了头场的起讲，也没有核对就交了卷。"
            n "交卷后你才想起写错了字，心里一阵慌乱，但幸好不同的部分在十个字以内，勉强过关。"
            $ wenyun += 1
            n "【系统提示】文运值+1"
            jump exam_part3

        "你觉得头场已经答得很好，二场无关紧要，便敷衍着写完了五经义的题目，默写也只写了大概。":
            n "你五经义题的部分写得很潦草，格式也不规范，默写的内容和头场相差甚远，甚至有些字完全记错了。"
            n "【坏结局提示】你的默写与头场不同的部分远超十个字，因此被判舞弊，失去考试资格。你将回到乡试第二场起始点。"
            jump exam_part2

# ================= 乡试第三场 =================
label exam_part3:
    n "八月十四日凌晨，你又一次站在贡院大门外，按流程第三次走进号舍，这是乡试的最后一场，考完这场，你人生第一次乡试，就全部结束了。"
    n "八月十五日清晨，题纸发放，第三场的试题是五道策问题，全是议论古今政治得失的题目。"
    n "其中一道题极为冷僻，问的是前朝的漕运制度沿革，题干就有几百字，看得人头晕目眩。而且今日是中秋节，你的友人昨日约你赏月饮酒。"

    menu:
        "你权衡利弊，做出了选择："

        "摒除杂念，认认真真分析每一道策问题，结合史书与自己的见解，逐题作答，哪怕写到十六日清晨，也要把每一道题都答得详实周全。":
            n "你沉下心来，一道一道分析策问题，哪怕是那道冷僻的漕运题，你也结合自己读过的史书，理清了沿革脉络，写出了自己的见解，没有敷衍拼接题干。"
            n "中秋夜，号巷里的考生一个个提前交卷离场，外面传来阵阵欢声笑语。"
            n "你却丝毫不受影响，一直写到十六日清晨，才把五道策问题全部答完，反复核对无误后，才交了卷。"
            $ wenyun += 4
            n "【系统提示】文运值+4"

        "按规矩答完所有题目，冷僻的题目结合题干内容整理作答，十五日傍晚写完，提前交卷离场，和友人过中秋。":
            n "你认认真真答完了所有题目，那道冷僻的漕运题，你结合题干里的内容，加上自己的理解，整理出了通顺的答案，没有敷衍拼接。"
            n "十五日傍晚，你写完了所有内容，核对无误后交了卷，走出贡院，和等候多时的亲友一起赏月过中秋，紧绷了大半个月的神经终于放松了下来。"
            $ wenyun += 2
            n "【系统提示】文运值+2"

        "敷衍了事，把题干里的句子拼接起来凑成答案，十五日中午就草草写完交卷，出去饮酒赏月。":
            n "你觉得策问无关紧要，便把题干里的句子拼接起来，草草凑成了答案，十五日中午就交了卷，出去和同伴饮酒赏月，玩了一整夜。"
            n "可你不知道，三场策问是考官评定考生才学的关键，敷衍的答卷会让考官认定你胸无点墨，哪怕头场二场答得再好，也会把你黜落。"
            $ wenyun -= 2
            n "【系统提示】文运值-2"

    jump final_results

# ================= 最终放榜与结局 =================
label final_results:
    n "九月初，省城贡院门外。天还没亮，贡院门前就已经人山人海，挤得水泄不通，"
    n "只听一阵锣鼓声响起，十几个衙役抬着一张巨大的红底黑字榜单走了出来，榜单右面画着腾云的龙，左面画着下山的虎 —— 正是乡试龙虎榜。"
    n "衙役们踩着梯子，把龙虎榜高高挂在了贡院墙上。"
    n "人群瞬间炸开了锅，你挤在人群里，眼睛死死盯着榜单，一个名字一个名字往下看。"

    # 根据文运值结算结局。全篇最高可得约17分左右。
    if wenyun >= 12:
        n "你在榜单的前二十名里，看到了自己的姓名、乡贯与生员等级。"
        n "一瞬间，你浑身的血液都冲上了头顶，耳边的喧哗声仿佛都消失了，"
        n "十年寒窗的苦读、日夜不辍的背诵、考场里的煎熬，在这一刻全部涌了上来，你红了眼眶，却忍不住笑了出来。"
        n "身边的仆从立刻冲了上来，给你披上早就准备好的红绸，高声喊着"
        "仆从" "恭喜少爷高中举人！"
        n "周围的人纷纷围上来道贺，谁都没想到，你第一次赴考，就能考中乡试前列，成了全省闻名的少年举人。"
        n "你按规矩前往考官府邸，拜见正副主考官（座师）、同考官（房师），行弟子之礼，感谢他们的赏识。"
        n "你受邀参加鹿鸣宴，宴席上，众人先向北面叩拜，谢天子之恩，随后在乐曲中开席。"
        n "宴席上还有一位六十年前中举的老人，重赴鹿鸣宴，众人纷纷上前拜见，满座皆欢。"
        n "你随即向学政提交了亲供，详细填写了姓名、年龄、身高、本籍、祖上三代的姓名与存殁情况，录入官方档案。"
        n "布政司按规矩给你下发了二十两牌坊银（旗匾银），还有衣帽银，让你在家门前建立坊门，纪念中举，定制新的举人官服"
        n "你派快马赶回家乡，给家人送去捷报，报喜的人一路敲锣打鼓，把你少年中举的消息传遍了整个县城，你的父母在家门前喜极而泣，十年的期许，终于有了最好的结果。"
        n "【结局：少年举人，金榜题名】"
        
    elif wenyun >= 5:
        n "你把正榜来来回回看了三遍，都没有找到自己的名字，心里瞬间凉了半截。"
        n "就在你失魂落魄的时候，同伴拉着你道"
        "同伴" "贤弟！副榜！副榜上有你的名字！"
        n "你猛地回头，只见正榜旁边的副榜上，赫然写着你的名字。"
        n "乡试副榜，又称 “副贡”，虽不算正式举人，不能入京参加会试，但可以进入国子监读书，下次乡试可以直接入场，不用再参加秀才的录科考试，也算是半个功名。"
        n "你看着副榜上的名字，心里五味杂陈，第一次赴考虽未中举，却也有所收获，不算全然白费。"
        n "你按规矩支付了费用，买回了自己的朱卷副本，看着上面考官的评语，知道了自己的问题所在。"
        n "你收拾好行装，回到家乡，准备进入国子监读书，三年之后，再赴秋闱，一争正榜。"
        n "【结局：名落副榜，蓄势待发】"
        
    else:
        n "你把正榜、副榜来来回回看了十几遍，都没有找到自己的名字。周围的欢呼、哭泣、道贺声，仿佛都成了针，扎在你的心上。你瘫坐在贡院门前的石阶上，脑子里一片空白。"
        n "十年寒窗，第一次乡试，你还是落榜了。"
        n "你想起家里满怀期许的父母，想起书院先生对你的夸赞，想起自己临行前的誓言，只觉得喉咙发紧，眼眶发酸。"
        n "你失魂落魄地回到客栈，买回了自己的朱卷副本。看着上面的评语，你恍然醒悟自己的态度还是不够认真。"
        n "于是你收拾好行装，回到了家乡，有人同情，有人嘲讽。"
        n "你把自己关在书房里，看着满架的经书，暗暗发誓，三年之后，定要再赴秋闱，一雪今日之耻。"
        n "【结局：名落孙山，重头再来】"

    return